# --- Required ---
# Convex: run `npx convex dev` and paste the deployment URL it prints.
NEXT_PUBLIC_CONVEX_URL=

# Ollama (chat, embeddings, summarize). Example: http://127.0.0.1:11434 or your LAN/Tailscale host.
OLLAMA_BASE_URL=http://127.0.0.1:11434

# --- Optional (sensible defaults in code) ---
# Text generation model (Ollama `ollama pull <name>`). Default: qwen3.5:9b
# OLLAMA_TEXT_MODEL=qwen3.5:9b

# Embeddings for RAG (ingest + chat retrieval). Default: nomic-embed-text
# OLLAMA_EMBEDDING_MODEL=nomic-embed-text

# Protect POST /api/summarize when exposed publicly
# SUMMARIZE_API_KEY=

# Summary API tuning (see README)
# SUMMARY_MAX_TOKENS=512
# SUMMARY_MAX_SOURCE_CHARS=16000
# SUMMARY_TIMEOUT_MS=120000
# SUMMARY_NUM_CTX=
